rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /objects/{objectId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /anchors/{document=**} {
      allow read, write: if true;
    }
  }
}
