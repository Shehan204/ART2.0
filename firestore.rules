rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // AR objects collection — the collection the app actually writes to
    match /objects/{document=**} {
      allow read, write: if true;
    }

    match /adminModels/{document=**} {
      allow read, write: if true;
    }

    // Legacy anchors collection (unused but kept for safety)
    match /anchors/{document=**} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
